{
	"name": "@finesoft/server",
	"version": "0.1.0",
	"private": true,
	"description": "Server factory: one-shot Hono + Vite + SSR setup for Node/Deno/Bun",
	"license": "MIT",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch"
	},
	"dependencies": {
		"@finesoft/ssr": "workspace:*"
	},
	"peerDependencies": {
		"@hono/node-server": "^1.0.0",
		"hono": "^4.0.0",
		"vite": "^5.0.0 || ^6.0.0"
	},
	"peerDependenciesMeta": {
		"@hono/node-server": {
			"optional": true
		},
		"vite": {
			"optional": true
		}
	},
	"devDependencies": {
		"@hono/node-server": "^1.14.1",
		"@types/node": "^22.19.15",
		"dotenv": "^17.3.1",
		"hono": "^4.7.10",
		"tsup": "^8.5.0",
		"typescript": "^5.3.0",
		"vite": "^5.0.0"
	}
}
