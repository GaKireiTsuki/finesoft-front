{
	"name": "@finesoft/core",
	"version": "0.1.0",
	"private": true,
	"description": "Core framework: router, DI container, actions, intents, and data pipeline",
	"license": "MIT",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch"
	},
	"devDependencies": {
		"tsup": "^8.5.0",
		"typescript": "^5.3.0"
	}
}
