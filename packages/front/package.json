{
    "name": "@finesoft/front",
    "version": "0.1.43",
    "description": "Full-stack framework: router, DI, actions, SSR, and server — all in one package",
    "license": "MIT",
    "files": [
        "dist",
        "README.md"
    ],
    "type": "module",
    "main": "dist/index.mjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "scripts": {
        "build": "vp pack",
        "dev": "vp pack --watch",
        "prepack": "node ../../scripts/prepare-front-publish.mjs",
        "postpack": "node ../../scripts/restore-front-publish.mjs"
    },
    "dependencies": {},
    "devDependencies": {
        "@finesoft/browser": "workspace:*",
        "@finesoft/core": "workspace:*",
        "@finesoft/server": "workspace:*",
        "@finesoft/ssr": "workspace:*",
        "@hono/node-server": "^1.14.1",
        "@types/node": "catalog:",
        "dotenv": "^17.3.1",
        "hono": "^4.7.10",
        "vite": "catalog:",
        "vite-plus": "catalog:"
    },
    "peerDependencies": {
        "@hono/node-server": "^1.0.0",
        "hono": "^4.0.0",
        "vite": ">=5.0.0"
    },
    "peerDependenciesMeta": {
        "@hono/node-server": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    }
}
