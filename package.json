{
    "name": "finesoft-front-monorepo",
    "private": true,
    "type": "module",
    "scripts": {
        "ready": "vp fmt && vp lint && vp run build -r",
        "build:packages": "vp run build -r",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "vp run build -r && changeset publish --access public",
        "release:auto:changeset": "node ./scripts/auto-changeset.mjs",
        "prepare": "vp config"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "typescript": "catalog:",
        "vite-plus": "catalog:"
    },
    "engines": {
        "node": ">=22.12.0"
    },
    "packageManager": "pnpm@10.32.1"
}
